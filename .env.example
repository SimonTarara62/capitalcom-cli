# Capital.com CLI credentials. Copy to .env and fill in.
# Resolution order: --env-file flag > $CAP_ENV_FILE > ./.env > ~/.config/capital-cli/.env

# Environment: demo or live (default: demo)
CAP_ENV=demo
# API Key from Capital.com Settings > API integrations
CAP_API_KEY=ENTER_GENERATED_API_KEY
# Your Capital.com login email
CAP_IDENTIFIER=ENTER_YOUR_EMAIL
# API Key custom password (NOT your platform password)
CAP_API_PASSWORD=ENTER_YOUR_API_PASSWORD

# --- Credential-exec helpers (keep secrets out of this file) ---
# Instead of a plaintext value above, source each secret from a command at
# runtime (1Password, pass, vault, etc.). If set AND the matching CAP_<FIELD>
# value is NOT explicitly set in the environment, the command is run and its
# stdout (trimmed) is used. Precedence: explicit env var > CAP_*_CMD > .env value.
# CAP_API_KEY_CMD=op read op://vault/capital/api-key
# CAP_IDENTIFIER_CMD=op read op://vault/capital/identifier
# CAP_API_PASSWORD_CMD=pass capital/api-password

# --- Trading safety (defaults are safe: trading off) ---
CAP_ALLOW_TRADING=false
CAP_ALLOWED_EPICS=
CAP_MAX_POSITION_SIZE=1.0
CAP_MAX_WORKING_ORDER_SIZE=1.0
CAP_MAX_OPEN_POSITIONS=3
CAP_MAX_ORDERS_PER_DAY=20
CAP_REQUIRE_EXPLICIT_CONFIRM=true
CAP_DRY_RUN=false

# --- Optional ---
# CAP_DEFAULT_ACCOUNT_ID=
CAP_HTTP_TIMEOUT_S=15
CAP_LOG_LEVEL=WARNING
CAP_WS_ENABLED=false
# Audit log: when set to a file path, each executed mutation (execute/close/
# cancel/amend) appends one JSONL line (timestamp, command, env, account, deal
# reference, status — no secrets). Disabled by default (unset = no writes).
# CAP_AUDIT_LOG=~/.config/capital-cli/audit.log
