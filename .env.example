# Capital.com CLI credentials. Copy to .env and fill in.
# Resolution order: --env-file flag > $CAP_ENV_FILE > ./.env > ~/.config/capital-cli/.env

# Environment: demo or live (default: demo)
CAP_ENV=demo
# API Key from Capital.com Settings > API integrations
CAP_API_KEY=ENTER_GENERATED_API_KEY
# Your Capital.com login email
CAP_IDENTIFIER=ENTER_YOUR_EMAIL
# API Key custom password (NOT your platform password)
CAP_API_PASSWORD=ENTER_YOUR_API_PASSWORD

# --- Trading safety (defaults are safe: trading off) ---
CAP_ALLOW_TRADING=false
CAP_ALLOWED_EPICS=
CAP_MAX_POSITION_SIZE=1.0
CAP_MAX_WORKING_ORDER_SIZE=1.0
CAP_MAX_OPEN_POSITIONS=3
CAP_MAX_ORDERS_PER_DAY=20
CAP_REQUIRE_EXPLICIT_CONFIRM=true
CAP_DRY_RUN=false

# --- Optional ---
# CAP_DEFAULT_ACCOUNT_ID=
CAP_HTTP_TIMEOUT_S=15
CAP_LOG_LEVEL=WARNING
CAP_WS_ENABLED=false
